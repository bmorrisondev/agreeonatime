# Convex — run `pnpm convex:dev` to link a project; CLI writes deployment to .env.local
# Dev:  fastidious-cardinal-591 — Prod: hearty-grasshopper-692 (EAS `production` profile)
# EXPO_PUBLIC_CONVEX_URL=   (https://….convex.cloud)
EXPO_PUBLIC_CONVEX_URL=
# Same deployment’s HTTP site origin for Better Auth (https://….convex.site)
EXPO_PUBLIC_CONVEX_SITE_URL=

# Sign in with Apple (omit or false for v1.0 App Store — button hidden)
# EXPO_PUBLIC_APPLE_SIGN_IN_ENABLED=true

# App Store review test account (production only — see scripts/create-apple-review-user.sh)
# REVIEW_EMAIL=
# REVIEW_PASSWORD=

# Where Expo web is served (Convex env `SITE_URL`) — comma-separated web origins for auth CORS.
# Production: https://app.agreeonatime.com — Vercel previews also match `https://app-agreeonatime-com-*` in code.
# SITE_URL=https://app.agreeonatime.com,http://localhost:8081,http://127.0.0.1:8081

# Vercel (app-agreeonatime-com): set EXPO_PUBLIC_CONVEX_URL and EXPO_PUBLIC_CONVEX_SITE_URL
# in Project Settings → Environment Variables for Production + Preview, then redeploy.

# App environment — EAS production profile sets `production` (hides Settings developer UI)
# EXPO_PUBLIC_APP_ENV=production

# Developer Settings sections (preview/dev only; never set on production builds)
# EXPO_PUBLIC_DEV_TOOLS=true

# Convex dev deployment only — allows Settings “Simulate Agree+” toggle (never production)
# DEV_PRO_OVERRIDE_ENABLED=true

# EAS local build + TestFlight (`pnpm deploy:testflight:local`)
# EXPO_TOKEN — required for non-interactive EAS (https://expo.dev/settings/access-tokens)
# EXPO_APPLE_APP_SPECIFIC_PASSWORD — required for submit (https://appleid.apple.com/account/manage)
EXPO_APPLE_APP_SPECIFIC_PASSWORD=

# EAS CLI (CI / non-interactive) — https://expo.dev/settings/access-tokens
EXPO_TOKEN=

# Convex CLI / CI (keep secret)
CONVEX_DEPLOY_KEY=

# Transactional email (server-side only — never EXPO_PUBLIC)
RESEND_API_KEY=

# Push notifications (Expo / EAS project id for registering tokens)
EXPO_PUBLIC_PROJECT_ID=

# RevenueCat public SDK keys (safe to expose in client bundles)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
# Web Billing key from RevenueCat → Web Billing config (`rcb_…` or test store `test_…`)
EXPO_PUBLIC_REVENUECAT_API_KEY_WEB=

# Expo Push API (Convex server — send from actions; never EXPO_PUBLIC)
EXPO_ACCESS_TOKEN=
# Better Auth — generate a strong secret for production; never ship raw secret to git
BETTER_AUTH_SECRET=

# Sign in with Apple (Convex HTTP / Better Auth `socialProviders.apple`)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PKCS8 private key contents (escape newlines as \\n in env files)
APPLE_PRIVATE_KEY=
APPLE_APP_BUNDLE_IDENTIFIER=me.brianmm.agreeonatime

# Magic link email (optional — without RESEND_API_KEY, links are logged server-side)
RESEND_FROM_EMAIL=
# Reminder email unsubscribe HMAC (Convex deployment only — generate a random secret)
REMINDER_UNSUBSCRIBE_SECRET=
# Dev-only: enable Settings → Send test reminder email (Convex deployment only)
# DEV_REMINDER_TEST_ENABLED=true

# RevenueCat — iOS public API key (`appl_…`) — Project → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
# RevenueCat — Web Billing public API key (`rcb_…`) — Apps & Providers → Web Billing
EXPO_PUBLIC_REVENUECAT_API_KEY_WEB=

# RevenueCat secret API key (Convex deployment only — never EXPO_PUBLIC)
REVENUECAT_SECRET_API_KEY=
# API v2 secret for scripts/MCP only (pnpm run setup:revenuecat-web) — never EXPO_PUBLIC
REVENUECAT_API_V2_SECRET=
# Bearer token for POST /revenuecat-webhook (Convex HTTP site URL + this path)
REVENUECAT_WEBHOOK_AUTHORIZATION=

# Google AdMob (DEV-451) — public app/ad unit ids; omit in dev to use Google sample/test ids
# App ids (~suffix) for native config plugin — defaults to Google sample app ids when unset
# EXPO_PUBLIC_ADMOB_APP_ID_IOS=
# EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=
# Ad unit ids (/suffix) for production builds — __DEV__ uses Google TestIds on native
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_IOS=
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID_IOS=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_UNIT_ID_ANDROID=
# Optional future web banner slot (no native SDK on web export)
# EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_WEB=
