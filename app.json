{
  "expo": {
    "name": "Agree on a Time",
    "slug": "agreeonatime",
    "version": "1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1C1A2E"
    },
    "scheme": "agreeonatime",
    "userInterfaceStyle": "automatic",
    "ios": {
      "deploymentTarget": "16.4",
      "bundleIdentifier": "me.brianmm.agreeonatime",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:app.agreeonatime.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "me.brianmm.agreeonatime",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "./plugins/withIosPodsDeploymentTarget",
        {
          "minimumIosVersion": "16.4"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#1C1A2E",
          "enableFullScreenImage_legacy": true
        }
      ],
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B5C"
        }
      ],
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "Agree on a Time checks your Apple Calendar for scheduling conflicts. Calendar data stays on your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0184258a-dbc7-4ea4-8540-e69f337d2318"
      }
    },
    "owner": "brianmmdev"
  }
}
