{
  "name": "agreeonatime",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "convex:dev": "convex dev",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:splash": "node ./scripts/generate-splash.mjs",
    "test:e2e": "playwright test",
    "prebuild:device": "pnpm install --prefer-offline",
    "build:device": "eas build --profile development-device --platform ios --local --output ./builds/agreeonatime.ipa && ./scripts/install-on-device.sh",
    "prebuild:preview": "pnpm install --prefer-offline",
    "build:preview": "bash ./scripts/build-preview.sh",
    "build:preview:sim": "bash ./scripts/build-preview-simulator.sh",
    "ios:release": "expo run:ios --configuration Release",
    "prebuild:sim": "pnpm install --prefer-offline",
    "build:sim": "eas build --profile development --platform ios --local --output ./builds/agreeonatime.tar.gz",
    "export:app-icon": "node ./scripts/export-app-icon.mjs"
  },
